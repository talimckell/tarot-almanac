// The Tarot Almanac — data model.
// Auth itself is Supabase's (auth.users, not modeled here). Profile mirrors that user by id
// (the Supabase UUID) so the app has somewhere to keep everything auth.users doesn't hold.
//
// Scoped to what unblocks accounts + /me + the giftable-chart library (build order step 4-5),
// plus the sharing fields for /chart/[person] and /gift/[token] (step 6).

generator client {
  provider = "prisma-client-js"
}

// Prisma 7: connection URLs are no longer set here. The CLI (migrate, etc.) reads them from
// prisma.config.ts; the runtime PrismaClient gets them via a driver adapter (lib/prisma.ts).
datasource db {
  provider = "postgresql"
}

model Profile {
  id    String  @id // matches Supabase auth.users.id — set on first sign-in, not generated here
  email String  @unique
  name  String?

  // The account holder's own birthdate — full date, since the natal chart (unlike the
  // year-excluded Bearing/personal daily track) needs birth year. lib/almanac.ts's
  // personalYear/Month/Day functions only ever need birthMonth/birthDay from this.
  birthDate DateTime?

  // Mirrors Stripe directly rather than an enum — statuses match Stripe's own strings
  // ("active", "canceled", "past_due", ...) so a webhook can write it through unchanged.
  stripeCustomerId             String?   @unique
  stripeSubscriptionId         String?   @unique
  subscriptionStatus           String?
  subscriptionCurrentPeriodEnd DateTime?

  // Set when the account holder buys the $12 one-off to unlock their OWN chart
  // without subscribing. Distinct from SavedChart.purchasedPaymentIntentId (charts
  // made for OTHER people) since the account holder's own chart isn't a SavedChart
  // row — it's computed live from birthDate.
  ownChartPurchasedPaymentIntentId String?

  savedCharts     SavedChart[]
  monthlyReadings MonthlyReading[]
  yearReadings    YearReading[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// A natal chart made for someone else (or yourself, separately from your own living
// almanac) — the giftable, fixed object described in the product plan. Access to a given
// chart comes from either an active subscription at creation time, or a one-off $12
// purchase; purchasedPaymentIntentId is set only for the latter.
model SavedChart {
  id      String  @id @default(cuid())
  ownerId String
  owner   Profile @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name      String // the person's name, e.g. "Mom"
  birthDate DateTime // full date — the natal chart runs the daily engine on this date

  // Set if this specific chart was bought one-off ($12), null if it was covered by an
  // active subscription at creation time. @unique doubles as the webhook's idempotency
  // key (upsert on this field), so duplicate Stripe event delivery can't double-create.
  purchasedPaymentIntentId String? @unique

  // /gift/[token]'s lookup key, separate from the primary id so a leaked gift link
  // can be revoked (regenerate this) without disturbing /chart/[person]'s own id.
  shareToken String @unique @default(cuid())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

// The monthly reading: one per (account holder, calendar month), ever. Personal only —
// there is no equivalent for a SavedChart, since the living almanac can't be generated
// for anyone but the account holder (see MONTHLY_READING_BUILD_BRIEF.md's hard boundaries).
// Generated lazily the first time an open month (current, or current+1 if a subscriber
// looks ahead) is requested; the row is then terminal — "ready" or "failed" — and is
// never regenerated, matching the no-regen/one-call-per-month cost model.
model MonthlyReading {
  id        String  @id @default(cuid())
  profileId String
  profile   Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  month String // "YYYY-MM"

  status String // "ready" | "failed" — terminal; a failed generation is never retried
  // automatically (that would defeat the one-call cost cap). A human clears it manually.

  // Set only when status = "ready": the AI's six prose slots, keyed exactly to
  // MONTHLY_READING_PROMPT_v1.md's OUTPUT CONTRACT (framing, cycleLine, weekTextures,
  // circledNotes, woven, reflections, evenMonthNote).
  sections Json?

  // Set only when status = "failed" — "api_error" | "parse_error" | "voice_gate", so a
  // real error and a held-for-review voice-gate failure can be told apart later.
  failureReason String?
  // The raw generation that failed the voice gate (banned tokens), kept for owner
  // review since there's no regen to just try again — same shape as `sections` would be.
  heldSections Json?

  createdAt DateTime @default(now())

  @@unique([profileId, month])
}

// A paid year-ahead reading: a fixed, giftable artifact for one (birthday, calendar year),
// bought one-off ($12) or gifted. Unlike MonthlyReading (per-account, the living almanac),
// this is a chart-like object — it can be made for anyone and opened by its shareToken, so it
// carries the recipient's name/birthday/reading year rather than being tied to the owner's own
// account state. The woven AI sections generate once on first view (pending → ready|failed) and
// are never regenerated, matching MonthlyReading's one-call cost model. The authored year and
// month readings the report shows are not stored here — they're wired live from the card data.
model YearReading {
  id      String  @id @default(cuid())
  ownerId String
  owner   Profile @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  name        String // the person the reading is for
  birthMonth  Int // 1-12  (birth year is not used by the year-card math, so it isn't stored)
  birthDay    Int // 1-31
  readingYear Int // the calendar year the reading covers

  // Denormalized deterministic anchors so a gift/list view needn't recompute them.
  yearCardIndex Int
  bearingIndex  Int

  // Set if bought one-off ($12); null if covered by a subscription at creation time.
  // @unique doubles as the webhook's idempotency key (upsert), like SavedChart.
  purchasedPaymentIntentId String? @unique

  // /personal-year-card/reading/[token] lookup key, revocable independently of id.
  shareToken String @unique @default(cuid())

  // Generation state, same contract as MonthlyReading.
  status        String // "pending" | "ready" | "failed"
  sections      Json? // the woven slots (framing, bearingMeetsYear, stagesAndArc, elementWeather, reflections)
  failureReason String?
  heldSections  Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

// Tracks which cards the "Reclaimed Reversals" batch campaign (studio/reclaimed-reversals)
// has already posted, so a random pull never repeats a card until it's manually reset. A
// row here means "used," full stop — not tied to any account, since this is an internal
// marketing tool, not user-facing data. Not a JSON file on disk: Vercel's filesystem is
// ephemeral in production, so this state has to live in the real database to persist
// across deploys and requests.
model ReclaimedReversalUsage {
  id     String   @id @default(cuid())
  slug   String   @unique // the card's own slug, e.g. "three-of-cups" or "tower"
  usedAt DateTime @default(now())
}

// Generic "already generated" tracking for the Pinterest board tools (studio/pinterest-*).
// One shared table across all ~16 planned boards, keyed by (board, itemKey) rather than a
// table per board — e.g. board="birthday-tarot-card", itemKey="july-5" (a birthday slug), or
// board="major-gift", itemKey="tower" (a card slug) for later boards. Reset is scoped to a
// single board (delete where board = X), never all boards at once. Same reasoning as
// ReclaimedReversalUsage: this must be a real table, not a JSON file, since Vercel's
// filesystem is ephemeral in production.
model PinterestPinUsage {
  id      String   @id @default(cuid())
  board   String
  itemKey String
  usedAt  DateTime @default(now())

  @@unique([board, itemKey])
  @@index([board])
}
