# Copy this file to .env and fill in real values. .env is gitignored — never commit it.
# .env itself currently holds harmless placeholder values so the app builds without
# real accounts yet; replace them here as each service is set up.

# --- Database (Supabase Postgres, via Prisma) ---
# Supabase dashboard -> Project Settings -> Database -> Connection string.
# DATABASE_URL: the "Transaction pooler" URI (port 6543) — used by the running app.
# DIRECT_URL: the "Session"/direct URI (port 5432) — used only by Prisma Migrate/CLI,
# which needs a non-pooled connection.
DATABASE_URL="postgresql://postgres:[password]@[project-ref].pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# --- Supabase Auth ---
# Supabase dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="[anon public key]"
# Service role key: same page, "service_role" secret. Bypasses Row Level Security —
# server-side only, never expose to the browser (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY="[service role secret key]"

# --- Stripe ---
# Stripe dashboard -> Developers -> API keys. Use the *test* keys until launch.
STRIPE_SECRET_KEY="sk_test_..."
# Developers -> Webhooks -> add endpoint (.../api/webhooks/stripe) -> signing secret.
STRIPE_WEBHOOK_SECRET="whsec_..."
# Product catalog -> the two prices from PRODUCT_AND_PRICING_PLAN.md ($7/mo sub, $12 chart).
NEXT_PUBLIC_STRIPE_PRICE_ID_SUBSCRIPTION="price_..."
NEXT_PUBLIC_STRIPE_PRICE_ID_CHART="price_..."

# --- Site ---
# Used to build absolute URLs (Stripe redirects, auth callback links, OG tags).
# http://localhost:3000 in dev; https://tarotalmanac.com in production.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
